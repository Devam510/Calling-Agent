# ─────────────────────────────────────────────
# Calling Agent — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── Google Sheets ──────────────────────────────
# Full URL of your Google Sheet (with editor access shared to your Google account)
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/1QaZqLlxsrC9FDU9I9OyCsCn3i_eJJy1EtQEsIMNOVHk/edit?gid=0#gid=0

# Name of the worksheet/tab containing leads
GOOGLE_SHEET_WORKSHEET=Sheet1

# ── Groq ───────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Android Gateway ───────────────────────────
# IP address of the Android phone running the gateway app
ANDROID_GATEWAY_HOST=192.168.1.100
ANDROID_GATEWAY_PORT=8765

# ── Speech-to-Text (Whisper) ──────────────────
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
# VAD silence window — 900ms default tuned for Hindi (L003)
VAD_SILENCE_MS=900

# ── Text-to-Speech (Piper) ────────────────────
PIPER_VOICE=hi_IN-hemant-medium
# Path to the .onnx model file
PIPER_MODEL_PATH=models/hi_IN-hemant-medium.onnx

# ── Audio Strategy ─────────────────────────────
# Options: speakerphone | loopback
AUDIO_STRATEGY=speakerphone

# ── Call Behaviour ────────────────────────────
# Seconds to wait for pickup before marking no_answer
CALL_RING_TIMEOUT_SEC=45
# Random inter-call delay range (seconds) — prevents SIM flagging
INTER_CALL_DELAY_MIN_SEC=30
INTER_CALL_DELAY_MAX_SEC=120
# Max conversation turns before hanging up
MAX_CONVERSATION_TURNS=20

# ── Recording ─────────────────────────────────
RECORDING_ENABLED=true
RECORDING_FORMAT=mp3
RECORDINGS_DIR=recordings

# ── Server ────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── Session DB ────────────────────────────────
SESSION_DB_PATH=data/sessions.db
